# Скопируйте в .env и при необходимости измените.

# Секрет для подписи JWT (в продакшене — длинная случайная строка)
SECRET_KEY=change-me-in-prod

# Время жизни токена, минут
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Креды админа (по умолчанию admin:admin, как в ТЗ)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Путь к файлу SQLite
DATABASE_URL=sqlite:///./app.db

# Разрешённый origin фронтенда для CORS
FRONTEND_ORIGIN=http://localhost:5173
